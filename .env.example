# =============================================================
# NEXUS ERP — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# =============================================================

# --- DATABASE ---
DATABASE_URL="postgresql://nexus_user:nexus_pass@localhost:5432/nexus_erp?schema=public"
DATABASE_DIRECT_URL="postgresql://nexus_user:nexus_pass@localhost:5432/nexus_erp?schema=public"

# --- REDIS ---
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="nexus_redis_pass"

# --- JWT AUTH ---
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- NEXTAUTH (Frontend) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- AI PROVIDERS ---
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4-turbo-preview"
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"

ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
ANTHROPIC_MODEL="claude-opus-4-7"

# --- EMAIL ---
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="your-resend-api-key"
SMTP_FROM="noreply@nexuserp.com"

# --- STORAGE (S3-compatible) ---
S3_ENDPOINT="https://s3.amazonaws.com"
S3_BUCKET="nexus-erp-assets"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"
S3_PUBLIC_URL="https://assets.nexuserp.com"

# --- PAYMENTS ---
STRIPE_SECRET_KEY="sk_test_your-stripe-secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

MERCADOPAGO_ACCESS_TOKEN="your-mp-access-token"
MERCADOPAGO_PUBLIC_KEY="your-mp-public-key"

# --- WHATSAPP ---
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_TOKEN="your-whatsapp-token"
WHATSAPP_PHONE_ID="your-phone-number-id"

# --- FRONTEND ---
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="your-mp-public-key"

# --- BACKEND ---
NODE_ENV="development"
PORT=4000
CORS_ORIGINS="http://localhost:3000"
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- ENCRYPTION ---
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"
BCRYPT_ROUNDS=12

# --- MONITORING ---
SENTRY_DSN="your-sentry-dsn"
